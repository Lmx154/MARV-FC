{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build MARV-FC-RL-RP2354B",
			"type": "shell",
			"command": "cargo",
			"args": ["build", "--release"],
			"options": {
				"cwd": "${workspaceFolder}/device/MARV-FC-RL-RP2354B"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$rustc"
			]
		},
		{
			"label": "Flash MARV-FC-RL-RP2354B",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--release"],
			"options": {
				"cwd": "${workspaceFolder}/device/MARV-FC-RL-RP2354B",
				"env": {
					"DEFMT_LOG": "info"
				}
			},
			"problemMatcher": [
				"$rustc"
			]
		},
		{
			"label": "RTT attach MARV-FC-RL-RP2354B",
			"type": "shell",
			"command": "probe-rs",
			"args": [
				"attach",
				"--chip", "RP235x",
				"../../target/thumbv8m.main-none-eabihf/release/marv-fc-rl-rp2354b"
			],
			"options": {
				"cwd": "${workspaceFolder}/device/MARV-FC-RL-RP2354B",
				"env": {
					"DEFMT_LOG": "info"
				}
			},
			"problemMatcher": []
		},
		{
			"label": "Build PAYLOAD-CONTROLLER-RP2350",
			"type": "shell",
			"command": "cargo",
			"args": ["build", "--release"],
			"options": {
				"cwd": "${workspaceFolder}/device/PAYLOAD-CONTROLLER-RP2350"
			},
			"problemMatcher": [
				"$rustc"
			]
		},
		{
			"label": "Flash PAYLOAD-CONTROLLER-RP2350",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--release"],
			"options": {
				"cwd": "${workspaceFolder}/device/PAYLOAD-CONTROLLER-RP2350",
				"env": {
					"DEFMT_LOG": "info"
				}
			},
			"problemMatcher": [
				"$rustc"
			]
		},
		{
			"label": "RTT attach PAYLOAD-CONTROLLER-RP2350",
			"type": "shell",
			"command": "probe-rs",
			"args": [
				"attach",
				"--chip", "RP235x",
				"../../target/thumbv8m.main-none-eabihf/release/payload-controller-rp2350"
			],
			"options": {
				"cwd": "${workspaceFolder}/device/PAYLOAD-CONTROLLER-RP2350",
				"env": {
					"DEFMT_LOG": "info"
				}
			},
			"problemMatcher": []
		},
		{
			"label": "Build RP2354B-CROSSCORE-TESTS",
			"type": "shell",
			"command": "cargo",
			"args": ["build", "--release"],
			"options": {
				"cwd": "${workspaceFolder}/device/RP2354B-CROSSCORE-TESTS"
			},
			"problemMatcher": [
				"$rustc"
			]
		},
		{
			"label": "Flash RP2354B-CROSSCORE-TESTS",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--release"],
			"options": {
