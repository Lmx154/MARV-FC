# Key/value config for the Cerberus Gazebo bridge.
# These defaults match the MARV Gazebo world (`marv_field`) and F450 model (`marv_f450`).

topics.clock=/clock
topics.imu=/world/marv_field/model/marv_f450/link/base_link/sensor/imu_sensor/imu
topics.magnetometer=/world/marv_field/model/marv_f450/link/base_link/sensor/magnetometer_sensor/magnetometer
topics.air_pressure=/world/marv_field/model/marv_f450/link/base_link/sensor/air_pressure_sensor/air_pressure
topics.navsat=/world/marv_field/model/marv_f450/link/base_link/sensor/navsat_sensor/navsat

actuators.topic=/marv_f450/command/motor_speed
actuators.max_rotor_velocity_rad_s=1000.0
actuators.motor_1.direction=1
actuators.motor_2.direction=1
actuators.motor_3.direction=-1
actuators.motor_4.direction=-1

nominal_battery_voltage_v=12.3
synthetic_sensors=false
